# {{ ansible_managed }}
# datacenter
datacenter = "dc1"

# data_dir
data_dir = "/opt/consul"

# client_addr
client_addr = "0.0.0.0"

# ui
ui_config{
  enabled = true
}

# server
server = true

# bootstrap_expect
bootstrap_expect=1

# Bind addr
# bind_addr = "[::]" # Listen on all IPv6
bind_addr = "{{ wg_ip }}"

# Advertise addr - if you want to point clients to a different address than bind or LB.
advertise_addr      = "{{ wg_ip }}"
advertise_addr_wan  = "{{ wg_ip }}"
translate_wan_addrs = true

ports {
  grpc = 8502
}

# Enterprise License
# As of 1.10, Enterprise requires a license_path and does not have a short trial.
# license_path = "/etc/consul.d/consul.hclic"

# encrypt
# encrypt = "..."

